SERVER_PORT: "8080"
SECURITY_SSL_ENABLED: "false"
SERVER_CONTEXT_PATH: "/WebAPI"

DATASOURCE_DRIVERCLASSNAME: "org.postgresql.Driver"
DATASOURCE_URL: "jdbc:postgresql://omop-db:5432/omop"
DATASOURCE_USERNAME: "omop"
DATASOURCE_PASSWORD: "omop"
DATASOURCE_DIALECT: "postgresql"
DATASOURCE_DIALECT_SOURCE: "POSTGRESQL"
DATASOURCE_OHDSI_SCHEMA: "webapi"

SOURCE_NAME: "OHDSI Africa"
CDM_VERSION: "5.4"
ORGANIZATION_NAME: "OHDSI Africa"

# Flyway
FLYWAY_ENABLED: "true"
FLYWAY_DATASOURCE_DRIVERCLASSNAME: "org.postgresql.Driver"
FLYWAY_DATASOURCE_URL: "jdbc:postgresql://omop-db:5432/omop"
FLYWAY_DATASOURCE_USERNAME: "omop"
FLYWAY_DATASOURCE_PASSWORD: "omop"

FLYWAY_LOCATIONS: "classpath:db/migration/postgresql"
FLYWAY_SCHEMAS: "webapi"
FLYWAY_VALIDATEONMIGRATE: "false"
FLYWAY_BASELINEONMIGRATE: "true"
FLYWAY_OUTOFORDER: "true"

FLYWAY_PLACEHOLDERS_OHDSISCHEMA: "webapi"

# Security
SECURITY_PROVIDER: "DisabledSecurity"
SECURITY_CORS_ENABLED: "true"
SECURITY_ORIGIN: "*"

EXECUTIONENGINE_URL: "http://webapi:8080/WebAPI"
EXECUTIONENGINE_TOKEN: ""

EXECUTIONENGINE_UPDATESTATUSCALLBACK: "http://webapi:8080/WebAPI/executionservice/callbacks/submission/{id}/status/update/{password}"
EXECUTIONENGINE_RESULTCALLBACK: "http://webapi:8080/WebAPI/executionservice/callbacks/submission/{id}/result/{password}"

SECURITY_OAUTH_CALLBACK_UI: http://localhost:8180/Atlas/#/welcome
SECURITY_OAUTH_CALLBACK_API: http://localhost:8080/WebAPI/user/oauth/callback

EXECUTION_INVALIDATION_PERIOD: "1800000"
EXECUTION_INVALIDATION_MAXAGE_HOURS: "24"
EXECUTION_STATUS_PERIOD: "60000"

# OAuth keys (empty by default)
SECURITY_OAUTH_GITHUB_APIKEY: ""
SECURITY_OAUTH_GITHUB_APISECRET: ""
SECURITY_OAUTH_GOOGLE_APIKEY: ""
SECURITY_OAUTH_GOOGLE_APISECRET: ""
SECURITY_OAUTH_FACEBOOK_APIKEY: ""
SECURITY_OAUTH_FACEBOOK_APISECRET: ""

# Cache settings
CDM_RESULT_CACHE_WARMING_ENABLE: "false"
CDM_CACHE_ACHILLES_WARMING_ENABLE: "false"
CDM_CACHE_CRON_WARMING_ENABLE: "false"

CACHE_GENERATION_INVALIDAFTERDAYS: "7"
CACHE_GENERATION_CLEANUPINTERVAL: "86400"
CACHE_GENERATION_USEASYNC: "true"
CACHE_JOBS_COUNT: "2"

DATASOURCE_TOMCAT_MAX_ACTIVE: "50"
DATASOURCE_TOMCAT_MAX_IDLE: "10"
DATASOURCE_TOMCAT_MIN_IDLE: "5"

# Spring configs
SPRING_BATCH_REPOSITORY_TABLEPREFIX: "webapi.batch_"
SPRING_JPA_PROPERTIES_HIBERNATE_DEFAULT_SCHEMA: "webapi"
# activate profile
SPRING_PROFILES_ACTIVE: "atlas,security,oidc"